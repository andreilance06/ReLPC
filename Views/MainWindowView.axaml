<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ReLPC.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="ReLPC.Views.MainWindowView"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ReLPC"
        Background="#20100B"
        Width="1920"
        Height="1080"
        MinWidth="1280"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.Styles>
        <Style Selector="StackPanel Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="40" />
        </Style>
    </Window.Styles>
    <Grid>
        <Canvas Opacity="0.80">
            <Rectangle Width="2e6"
                       Height="{Binding $parent.Bounds.Height}"
                       Canvas.Top="-220"
                       Canvas.Left="-1e6"
                       Fill="#ff3131" />
            <Rectangle Width="2e6"
                       Height="{Binding $parent.Bounds.Height}"
                       Canvas.Bottom="-360"
                       Canvas.Left="-1e6"
                       Fill="#ff7846" />
            <Canvas.Effect>
                <BlurEffect Radius="500" />
            </Canvas.Effect>
        </Canvas>

        <Grid RowDefinitions="Auto, *, Auto">
            <StackPanel Grid.Row="0" Margin="8, 8, 8, 0" Orientation="Horizontal" VerticalAlignment="Center"
                        Spacing="3">
                <Image Source="/Assets/icons-logo/icon-logo.png" Width="40" Margin="10, 0"></Image>
                <Button Width="36"
                        Height="36"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip.Tip="Undo (Ctrl+Z)">
                    <Image Source="/Assets/elements/undo.png"
                           Height="20" />
                </Button>
                <Button Width="36"
                        Height="36"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip.Tip="Redo (Ctrl+Y)">
                    <Image Source="/Assets/elements/redo.png"
                           Height="20" />
                </Button>

            </StackPanel>

            <Grid Row="1" ColumnDefinitions="Auto, Auto, 500, *" Margin="8"
                  ColumnSpacing="3">

                <Border Name="MinDashboard" Grid.Column="0" Width="60" CornerRadius="8"
                        IsVisible="{Binding !IsMenuExpanded}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#CCFF4E3B" Offset="0" />
                            <GradientStop Color="#ff3131" Offset=".5" />
                            <GradientStop Color="#CFFF6A1E" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid RowDefinitions="Auto, *, Auto" HorizontalAlignment="Left">
                        <StackPanel Grid.Row="0"
                                    Margin="10"
                                    Spacing="16"
                                    HorizontalAlignment="Center">
                            <Button Command="{Binding ToggleMenuCommand}">
                                <Image Source="/Assets/elements/burger-menu.png" />
                            </Button>
                            <Button Command="{Binding ToggleDatasetPanelCommand}">
                                <Image Source="/Assets/elements/file-explorer.png" />
                            </Button>
                            <Button Command="{Binding CreateNewDatasetCommand}">
                                <Image Source="/Assets/elements/new-file.png" />
                            </Button>
                            <Button Command="{Binding PickAndLoadDatasetCommand}">
                                <Image Source="/Assets/elements/open-file.png" />
                            </Button>
                            <Button Command="{Binding ExportPdfCommand}">
                                <Image Source="/Assets/elements/export.png" />
                            </Button>
                            <Button Command="{Binding DeleteCurrentDatasetCommand}">
                                <Image Source="/Assets/elements/trash.png" />
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="10"
                                    Spacing="16"
                                    HorizontalAlignment="Center">
                            <Button Command="{Binding LogoutCommand}">
                                <Image Source="/Assets/elements/logout.png" />
                            </Button>
                        </StackPanel>
                    </Grid>


                </Border>

                <Border Name="MaxDashboard" Grid.Column="0" Width="200" CornerRadius="8"
                        IsVisible="{Binding IsMenuExpanded}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#CCFF4E3B" Offset="0" />
                            <GradientStop Color="#ff3131" Offset=".5" />
                            <GradientStop Color="#CFFF6A1E" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid RowDefinitions="Auto, *, Auto" HorizontalAlignment="Left">
                        <StackPanel Grid.Row="0"
                                    Margin="10"
                                    Spacing="16"
                                    HorizontalAlignment="Center">
                            <Button Command="{Binding ToggleMenuCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/burger-menu.png" />
                                    <TextBlock Text="MENU"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding GoToDashboardCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/dashboard.png" />
                                    <TextBlock Text="DASHBOARD"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ToggleDatasetPanelCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/file-explorer.png" />
                                    <TextBlock Text="DATASETS"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CreateNewDatasetCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/new-file.png" />
                                    <TextBlock Text="NEW DATASET"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PickAndLoadDatasetCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/open-file.png" />
                                    <TextBlock Text="LOAD DATASET"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExportPdfCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/export.png" />
                                    <TextBlock Text="EXPORT PDF"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteCurrentDatasetCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/trash.png" />
                                    <TextBlock Text="DELETE DATASET"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="10"
                                    Spacing="16"
                                    HorizontalAlignment="Left">
                            <Button Command="{Binding LogoutCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Source="/Assets/elements/logout.png" />
                                    <TextBlock Text="LOG OUT"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Name="DatasetPanel" Grid.Column="1" Width="160" CornerRadius="8" Background="White"
                        IsVisible="{Binding IsDatasetPanelVisible}">
                    <StackPanel Spacing="10" Margin="16,24">
                        <TextBlock Text="DATA SETS"
                                   FontSize="14"
                                   FontWeight="Black"
                                   Foreground="#ff3131" />
                        <ListBox ItemsSource="{Binding UserDatasets}"
                                 SelectedItem="{Binding SelectedDataset, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DashboardTitle}"
                                               FontSize="13"
                                               Foreground="#ff3131"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="8" Background="White">
                    <Grid RowDefinitions="Auto, *, Auto"
                          Margin="40, 20">
                        <StackPanel Grid.Row="0" Spacing="4">
                            <TextBox Text="{Binding DatasetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Dataset name"
                                     FontSize="14"
                                     Foreground="#885038"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"/>
                            <TextBlock Text="DATA ENTRY"
                                       FontFamily="Arial Black"
                                       FontSize="40"
                                       FontWeight="Black"
                                       Foreground="#ff3131"
                                       LetterSpacing="0" />
                            <TextBlock Text="ENTER YOUR DATA (X, Y) BELOW"
                                       Margin="4,-4,0,0"
                                       FontSize="14"
                                       Foreground="#ff3131" />
                        </StackPanel>

                        <!-- table of values -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Inputs}"
                                  AutoGenerateColumns="True"
                                  CellEditEnding="DataGrid_OnCellEditEnding"
                                  CurrentCellChanged="DataGrid_OnCurrentCellChanged"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="False"
                                  Foreground="#ff3131"
                                  Background="White"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#ff3131"
                                  VerticalGridLinesBrush="#ff3131"
                                  KeyDown="InputElement_OnKeyDown"
                                  BorderThickness="2"
                                  BorderBrush="#ff3131"
                                  Margin="0, 10">
                            <DataGrid.Styles>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#ff3131" />
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </DataGrid.Styles>
                        </DataGrid>

                        <!-- calculation settings -->
                        <Grid Row="2" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="4">
                            <TextBox Grid.Column="1"
                                     Width="110"
                                     Height="46"
                                     FontSize="14"
                                     Background="White"
                                     Foreground="#ff3131"
                                     BorderBrush="#ff3131"
                                     BorderThickness="1"
                                     CornerRadius="8"
                                     Padding="14, 7"
                                     VerticalContentAlignment="Center"
                                     PlaceholderText="Degree"
                                     Text="{Binding DegreeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox Grid.Column="2"
                                      Height="46"
                                      FontSize="14"
                                      Background="White"
                                      Foreground="#ff3131"
                                      BorderBrush="#ff3131"
                                      BorderThickness="1"
                                      CornerRadius="8"
                                      Padding="14, 7"
                                      VerticalContentAlignment="Center"
                                      SelectedIndex="{Binding SelectedRegressionIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Linear Regression" />
                                <ComboBoxItem Content="Polynomial Regression" />
                                <ComboBoxItem Content="Both" />
                            </ComboBox>
                        </Grid>

                    </Grid>
                </Border>

                <!-- calculation results -->
                <Border Grid.Column="3" CornerRadius="8" Background="White">
                    <Grid RowDefinitions="Auto, *, Auto"
                          Margin="40, 20">
                        <TextBlock Grid.Row="0" Text="RESULT"
                                   FontFamily="Arial Black"
                                   FontSize="40"
                                   FontWeight="Black"
                                   Foreground="#ff3131"
                                   LetterSpacing="0" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Margin="0, 24">
                            <StackPanel Spacing="8">

                                <TextBlock Text="EQUATION"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#ff3131" />
                                <Border MinHeight="64"
                                        BorderBrush="#40FF4E3B"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12">
                                    <TextBlock Text="{Binding Equation}"
                                               TextWrapping="Wrap"
                                               FontFamily="avares://ReLPC/Assets/fonts/latinmodern-math.otf#Latin Modern Math"
                                               FontSize="18"
                                               Foreground="#171717" />
                                </Border>

                                <TextBlock Text="COEFFICIENT"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#ff3131" />
                                <Border MinHeight="64"
                                        BorderBrush="#40FF4E3B"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12">
                                    <TextBlock Text="{Binding Coefficient}"
                                               TextWrapping="Wrap"
                                               FontFamily="avares://ReLPC/Assets/fonts/latinmodern-math.otf#Latin Modern Math"
                                               FontSize="16"
                                               Foreground="#171717" />
                                </Border>

                                <TextBlock Text="INTERMEDIATE COMPUTATIONS"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#ff3131" />
                                <Border MinHeight="64"
                                        BorderBrush="#40FF4E3B"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12">
                                    <TextBlock Text="{Binding Intermediates}"
                                               TextWrapping="Wrap"
                                               FontFamily="avares://ReLPC/Assets/fonts/latinmodern-math.otf#Latin Modern Math"
                                               FontSize="14"
                                               Foreground="#171717" />
                                </Border>


                                <TextBlock Text="PREDICTION"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#ff3131" />
                                <Border MinHeight="64"
                                        BorderBrush="#40FF4E3B"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="x ="
                                                       VerticalAlignment="Center"
                                                       FontSize="16"
                                                       Foreground="#171717" />
                                            <TextBox Width="160"
                                                     FontSize="14"
                                                     Background="White"
                                                     Foreground="#ff3131"
                                                     BorderBrush="#ff3131"
                                                     BorderThickness="1"
                                                     CornerRadius="8"
                                                     Padding="10, 5"
                                                     PlaceholderText="enter X"
                                                     Text="{Binding PredictionXText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Prediction}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="avares://ReLPC/Assets/fonts/latinmodern-math.otf#Latin Modern Math"
                                                   FontSize="16"
                                                   Foreground="#171717" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>


        </Grid>
    </Grid>

</Window>
