<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ReLPC.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        Width="800" Height="600"
        MinWidth="800" MinHeight="600"
        x:Class="ReLPC.Views.SignUpWindowView"
        x:DataType="vm:SignUpWindowViewModel"
        Title="Sign Up">

    <Window.Styles>
        <Style Selector="ToggleButton">
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <Style Selector="ToggleButton Image">
            <Setter Property="Source" Value="/Assets/elements/pass-open.png" />
        </Style>

        <Style Selector="ToggleButton:checked Image">
            <Setter Property="Source" Value="/Assets/elements/pass-close.png" />
        </Style>

        <Style Selector="ToggleButton:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Grid Name="PageRoot" Background="#FF5A47">
        <Border Name="SignUpPanel"
                Margin="28"
                CornerRadius="24"
                Background="#40FFFFFF"
                BorderBrush="#80FFFFFF"
                BorderThickness="1.2"
                BoxShadow="0 10 30 0 rgba(0,0,0,0.25)">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20">

                <!-- Title -->
                <TextBlock Text="Sign Up"
                           Foreground="White"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />

                <StackPanel Width="400" Spacing="16">

                    <!-- STUDENT ID -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="STUDENT ID"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                        <TextBox Height="48"
                                 FontSize="20"
                                 Foreground="#333333"
                                 Background="White"
                                 BorderBrush="White"
                                 BorderThickness="1.2"
                                 CornerRadius="10"
                                 Padding="12"
                                 Text="{Binding Username}" />
                    </StackPanel>

                    <!-- PASSWORD -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="PASSWORD"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                        <TextBox Height="48"
                                 FontSize="20"
                                 Foreground="#333333"
                                 Background="White"
                                 BorderBrush="White"
                                 BorderThickness="1.2"
                                 CornerRadius="10"
                                 Padding="12"
                                 PasswordChar="&#x25cf;"
                                 Text="{Binding Password}">
                            <TextBox.InnerRightContent>
                                <ToggleButton
                                    Click="HidePassword_OnClick"
                                    IsChecked="True">
                                    <Image />
                                </ToggleButton>
                            </TextBox.InnerRightContent>
                        </TextBox>
                    </StackPanel>

                    <!-- CONFIRM PASSWORD -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="CONFIRM PASSWORD"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                        <TextBox Height="48"
                                 FontSize="20"
                                 Foreground="#333333"
                                 Background="White"
                                 BorderBrush="White"
                                 BorderThickness="1.2"
                                 CornerRadius="10"
                                 Padding="12"
                                 PasswordChar="&#x25cf;"
                                 Text="{Binding PasswordConfirmation}">
                            <TextBox.InnerRightContent>
                                <ToggleButton
                                    Click="HidePassword_OnClick"
                                    IsChecked="True"
                                    IsThreeState="False">
                                    <Image />
                                </ToggleButton>
                            </TextBox.InnerRightContent>
                        </TextBox>
                    </StackPanel>

                    <TextBlock Text="{Binding SignupStatus}"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="20"
                               HorizontalAlignment="Center" />

                    <!-- BUTTON -->
                    <Button Content="SIGN UP"
                            Command="{Binding AttemptSignupCommand}"
                            IsEnabled="{Binding !AttemptSignupCommand.IsRunning}"
                            Width="200"
                            Height="48"
                            Background="White"
                            Foreground="#ff3131"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold" />

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>