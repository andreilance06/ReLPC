<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="ReLPC.Views.ConfirmDeleteDatasetWindowView"
        mc:Ignorable="d"
        Title="Delete Dataset"
        Width="420"
        Height="190"
        MinWidth="380"
        MinHeight="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Border Margin="8"
          Padding="26"
          Background="#FFF8F3"
          CornerRadius="14">
    <Grid RowDefinitions="*,Auto">
      <StackPanel Spacing="8">
        <TextBlock Text="Delete dataset?"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#171717"/>
        <TextBlock Text="This will permanently remove the current dataset."
                   FontSize="14"
                   TextWrapping="Wrap"
                   Foreground="#4A4A4A"/>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="10">
        <Button Content="Cancel"
                Width="88"
                Height="34"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="White"
                Foreground="#171717"
                BorderBrush="#CCFF4E3B"
                BorderThickness="1"
                CornerRadius="6"
                Click="OnCancelClick"/>
        <Button Content="Delete"
                Width="88"
                Height="34"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="#FFFF4E3B"
                Foreground="White"
                BorderBrush="#FFFF4E3B"
                BorderThickness="1"
                CornerRadius="6"
                Click="OnDeleteClick"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
